# Revenue Radar environment variables
# Copy this file to .env.local for development. Vercel project settings hold production values.
# Never commit .env.local. Every variable below is required unless marked optional.

# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Anthropic ----------
ANTHROPIC_API_KEY=

# ---------- Stripe (placeholder until Chase business account is live) ----------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_ANNUAL=
STRIPE_PRICE_SCALE_MONTHLY=
STRIPE_PRICE_SCALE_ANNUAL=

# ---------- HubSpot Public App ----------
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=https://revenueradar.digitalflowconsulting.ca/api/integrations/hubspot/callback

# ---------- Resend ----------
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@revenueradar.digitalflowconsulting.ca

# ---------- Sentry ----------
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ---------- Posthog ----------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---------- Inngest ----------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---------- Research APIs (needed Phase 2) ----------
EXA_API_KEY=
FIRECRAWL_API_KEY=
BUILTWITH_API_KEY=

# ---------- Phase 2+ optional ----------
CRUNCHBASE_API_KEY=

# ---------- Application ----------
NEXT_PUBLIC_APP_URL=https://revenueradar.digitalflowconsulting.ca
